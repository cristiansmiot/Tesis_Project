# ============================================================
# Variables de entorno - Backend IoT Medidor de Energia
# Copiar a .env y completar con valores reales
# En Railway: configurar estas variables en el panel de Settings
# ============================================================

# Base de datos PostgreSQL (Railway la provee automaticamente como DATABASE_URL)
USE_SQLITE=false
DATABASE_URL=postgresql://postgres:password@host:port/railway

# Configuración general
ENVIRONMENT=production
DEBUG=false

# MQTT - Broker Mosquitto en Railway
MQTT_BROKER=your-railway-host.proxy.rlwy.net
MQTT_PORT=58954
MQTT_USERNAME=medidor_iot
MQTT_PASSWORD=your_mqtt_password
MQTT_TOPIC_BASE=medidor/#
# Opcional: si se deja vacío se genera uno único automáticamente
MQTT_CLIENT_ID=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logs
LOG_LEVEL=INFO
